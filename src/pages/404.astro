---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found"
  description="This Ronan Peacock portfolio page could not be found."
  robots="noindex, follow"
>
  <section class="section">
    <div class="container">
      <div class="card max-w-2xl mx-auto p-8 sm:p-10 text-center">
        <p class="text-sm font-mono uppercase tracking-[0.2em] text-[var(--color-text-faint)] mb-4">
          404
        </p>
        <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-[var(--color-text)] mb-4">
          Page not found
        </h1>
        <p class="text-[var(--color-text-muted)] leading-relaxed mb-8">
          The page you tried to open is not here. Head back to the homepage to continue browsing.
        </p>
        <a
          href="/"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-[var(--color-accent)] text-white text-sm font-semibold hover:bg-[var(--color-accent-hover)] transition-colors duration-200"
        >
          Back to home
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
