---
import { site } from '../../data/site';
---

<section
  class="hero-section relative min-h-screen flex items-center pt-16 overflow-hidden"
  aria-label="Introduction"
>
  <!-- Dot grid background -->
  <div class="hero-grid" aria-hidden="true"></div>

  <!-- Radial accent glow -->
  <div class="hero-glow" aria-hidden="true"></div>

  <div class="container relative z-10">
    <div class="flex flex-col-reverse md:flex-row items-center gap-12 md:gap-20 py-20">

      <!-- Text content -->
      <div class="flex-1 max-w-xl">

        <p
          class="hero-animate inline-flex items-center gap-2 mb-5"
          style="animation-delay: 0.05s;"
        >
          <span class="mono-label">Software Engineer</span>
          <span class="inline-block w-1.5 h-1.5 rounded-full bg-[var(--color-accent)]" aria-hidden="true"></span>
          <span class="mono-label">Glasgow</span>
        </p>

        <h1
          class="hero-animate text-gradient text-5xl sm:text-6xl md:text-7xl font-extrabold tracking-tight leading-[1.05] mb-6"
          style="animation-delay: 0.15s;"
        >
          Ronan<br />Peacock
        </h1>

        <p
          class="hero-animate text-lg text-[var(--color-text)] leading-relaxed mb-4 max-w-2xl"
          style="animation-delay: 0.28s;"
        >
          Ronan Peacock is a software engineer in Glasgow, graduate apprentice at Leidos,
          and final-year BSc Software Engineering student at the University of Glasgow.
        </p>

        <p
          class="hero-animate text-base text-[var(--color-text-muted)] leading-relaxed mb-8 max-w-xl"
          style="animation-delay: 0.32s;"
        >
          I have 4 years of industry experience across cybersecurity, systems modernisation,
          public-sector web delivery, and maritime autonomy R&amp;D, and I am graduating in
          July 2026.
        </p>

        <div class="hero-animate mb-8" style="animation-delay: 0.38s;">
          <div class="flex flex-wrap gap-3">
          <a
            href="/projects"
            class="btn-primary inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-[var(--color-accent)] text-white text-sm font-semibold hover:bg-[var(--color-accent-hover)] transition-all duration-200 shadow-lg shadow-[var(--color-accent-muted)]"
          >
            View projects
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12"/>
              <polyline points="12 5 19 12 12 19"/>
            </svg>
          </a>
          <a
            href={site.cvPath}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg border border-[var(--color-border)] text-[var(--color-text-muted)] text-sm font-medium hover:border-[var(--color-border-hover)] hover:text-[var(--color-text)] transition-colors duration-200"
          >
            Download CV
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
              <polyline points="7 10 12 15 17 10"/>
              <line x1="12" y1="15" x2="12" y2="3"/>
            </svg>
          </a>
          <a
            href="/#contact"
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg border border-[var(--color-border)] text-[var(--color-text-muted)] text-sm font-medium hover:border-[var(--color-border-hover)] hover:text-[var(--color-text)] transition-colors duration-200"
          >
            Get in touch
          </a>
          </div>
          <p class="mt-2 text-xs text-[var(--color-text-faint)]">
            CV updated {site.cvLastUpdated}
          </p>
        </div>

        <!-- Social links -->
        <div
          class="hero-animate flex items-center gap-5"
          style="animation-delay: 0.46s;"
        >
          <a
            href={site.github}
            target="_blank"
            rel="noopener noreferrer"
            class="text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors duration-200"
            aria-label="GitHub"
          >
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
            </svg>
          </a>
          <a
            href={site.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors duration-200"
            aria-label="LinkedIn"
          >
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Headshot -->
      <div
        class="hero-animate shrink-0"
        style="animation-delay: 0.2s;"
      >
        <div class="headshot-wrapper relative w-64 h-64 md:w-80 md:h-80">
          <div class="headshot-glow" aria-hidden="true"></div>
          <img
            src="/assets/images/linkedin-profile-pic.jpg"
            alt="Ronan Peacock"
            width="320"
            height="320"
            class="relative z-10 w-full h-full object-cover rounded-2xl border border-[var(--color-border)]"
            loading="eager"
          />
        </div>
      </div>

    </div>
  </div>

  <!-- Scroll indicator -->
  <div
    class="scroll-hint absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1.5 text-[var(--color-text-faint)]"
    aria-hidden="true"
  >
    <span class="text-xs font-mono tracking-widest">scroll</span>
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <polyline points="6 9 12 15 18 9"/>
    </svg>
  </div>
</section>

<style>
  .hero-section {
    background-color: var(--color-bg);
    background-image:
      radial-gradient(ellipse 70% 60% at 20% 60%, rgba(14, 165, 233, 0.06) 0%, transparent 70%),
      radial-gradient(circle, rgba(0, 0, 0, 0.04) 1px, transparent 1px);
    background-size: auto, 28px 28px;
  }

  .hero-glow {
    position: absolute;
    top: -10%;
    right: -5%;
    width: 55%;
    height: 70%;
    background: radial-gradient(ellipse at center, rgba(14, 165, 233, 0.07) 0%, transparent 70%);
    pointer-events: none;
    animation: glowPulse 6s ease-in-out infinite;
  }

  .hero-section::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 80px;
    background: linear-gradient(to bottom, rgba(248, 250, 252, 0), #f8fafc);
    pointer-events: none;
  }

  .headshot-wrapper {
    isolation: isolate;
  }
  .headshot-glow {
    position: absolute;
    inset: -12px;
    border-radius: 24px;
    background: radial-gradient(ellipse at center, rgba(14, 165, 233, 0.18) 0%, transparent 70%);
    filter: blur(16px);
    z-index: 0;
  }

  .scroll-hint {
    animation: heroFadeIn 1s ease 1s both;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-glow { animation: none; }
    .scroll-hint { animation: none; opacity: 1; }
  }
</style>
