---
import { timeline } from '../../data/timeline';
import SectionHeading from '../ui/SectionHeading.astro';
import TechTag from '../ui/TechTag.astro';

const sorted = [...timeline].sort((a, b) => a.order - b.order);
---

<section id="experience" class="section section-tinted">
  <div class="container">
    <SectionHeading
      title="Experience"
      subtitle="4 years at Leidos as a Technical Graduate Apprentice, rotating through different engineering disciplines."
    />

    <div class="relative">
      <!-- Timeline vertical line -->
      <div
        class="timeline-line absolute left-[17px] top-6 bottom-6 w-px hidden sm:block"
        aria-hidden="true"
      ></div>

      <ol class="space-y-6" role="list">
        {sorted.map((entry, i) => (
          <li class="relative sm:pl-14 reveal" style={`transition-delay: ${i * 0.1}s`}>

            <!-- Timeline node -->
            <div
              class="timeline-node absolute left-0 top-4 w-9 h-9 rounded-full hidden sm:flex items-center justify-center text-xs font-mono font-bold text-[var(--color-accent)]"
              aria-hidden="true"
            >
              {String(entry.order).padStart(2, '0')}
            </div>

            <div class="card p-6">
              <div class="flex flex-wrap items-start justify-between gap-x-4 gap-y-1 mb-1">
                <h3 class="text-base font-bold text-[var(--color-text)] leading-snug">
                  {entry.title}
                </h3>
                <span class="period-badge text-xs font-mono shrink-0">
                  {entry.period}
                </span>
              </div>

              <p class="text-xs font-semibold text-[var(--color-accent)] mb-3 tracking-wide uppercase" style="letter-spacing: 0.06em;">
                Leidos &middot; Glasgow
              </p>

              <p class="text-sm text-[var(--color-text-muted)] leading-relaxed mb-4">
                {entry.description}
              </p>

              <ul class="space-y-1.5 mb-5">
                {entry.highlights.map((h) => (
                  <li class="flex items-start gap-2.5 text-sm text-[var(--color-text-muted)]">
                    <span class="text-[var(--color-accent)] mt-[5px] shrink-0" aria-hidden="true">
                      <svg width="6" height="6" viewBox="0 0 6 6" fill="currentColor">
                        <circle cx="3" cy="3" r="3"/>
                      </svg>
                    </span>
                    {h}
                  </li>
                ))}
              </ul>

              <div class="flex flex-wrap gap-1.5">
                {entry.tags.map((tag) => <TechTag label={tag} />)}
              </div>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </div>
</section>

<style>
  .timeline-line {
    background: linear-gradient(
      to bottom,
      transparent 0%,
      var(--color-border) 10%,
      var(--color-border) 90%,
      transparent 100%
    );
  }

  .timeline-node {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-accent);
    transition: border-color 0.2s ease, background-color 0.2s ease;
  }

  li:hover .timeline-node {
    border-color: var(--color-border-accent);
    background-color: var(--color-accent-muted);
  }

  .period-badge {
    color: var(--color-text-faint);
    background-color: var(--color-surface-raised);
    border: 1px solid var(--color-border);
    padding: 0.15rem 0.55rem;
    border-radius: 20px;
  }
</style>
