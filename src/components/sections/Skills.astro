---
import SectionHeading from '../ui/SectionHeading.astro';
import TechTag from '../ui/TechTag.astro';
import { skillGroups } from '../../data/skills';
---

<section id="skills" class="section">
  <div class="container">
    <SectionHeading title="Skills" />

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {skillGroups.map((group, i) => (
        <div
          class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-[var(--radius-card)] p-5 reveal"
          style={`transition-delay: ${i * 0.07}s`}
        >
          <h3 class="text-xs font-mono text-[var(--color-accent)] uppercase tracking-widest mb-3">
            {group.label}
          </h3>
          <div class="flex flex-wrap gap-1.5">
            {group.skills.map((skill) => <TechTag label={skill} />)}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
