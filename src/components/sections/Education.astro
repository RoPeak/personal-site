---
import SectionHeading from '../ui/SectionHeading.astro';
import { degree, academicYears, dissertations } from '../../data/education';
---

<section id="education" class="section">
  <div class="container">
    <SectionHeading title="Education" />

    <!-- Degree card -->
    <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-[var(--radius-card)] p-6 mb-8 reveal">
      <div class="flex flex-wrap items-start justify-between gap-3 mb-2">
        <h3 class="text-lg font-semibold text-[var(--color-text)]">{degree.title}</h3>
        <span class="text-xs font-mono text-[var(--color-text-faint)]">Expected {degree.expectedGraduation}</span>
      </div>
      <p class="text-sm text-[var(--color-accent)] font-medium mb-1">{degree.institution}</p>
      <p class="text-xs text-[var(--color-text-faint)] mb-3">{degree.type}</p>
      <p class="text-sm text-[var(--color-text-muted)]">{degree.standing}</p>
    </div>

    <!-- Modules (collapsible) -->
    <div class="mb-10 reveal" style="transition-delay: 0.1s;">
      <details class="group">
        <summary
          class="cursor-pointer flex items-center justify-between w-full p-4 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-[var(--radius-card)] text-sm font-medium text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:border-[var(--color-border-hover)] transition-colors list-none"
          aria-label="Toggle module list"
        >
          <span>Modules studied (Years 1-4)</span>
          <svg
            class="w-4 h-4 transition-transform duration-200 group-open:rotate-180"
            viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
            aria-hidden="true"
          >
            <polyline points="6 9 12 15 18 9" />
          </svg>
        </summary>
        <div class="mt-2 border border-[var(--color-border)] rounded-[var(--radius-card)] overflow-hidden">
          {academicYears.map((year, i) => (
            <div class={`p-5 ${i < academicYears.length - 1 ? 'border-b border-[var(--color-border)]' : ''}`}>
              <h4 class="text-xs font-mono text-[var(--color-accent)] uppercase tracking-widest mb-3">
                {year.label}
              </h4>
              <ul class="space-y-1.5">
                {year.modules.map((mod) => (
                  <li class="flex items-start gap-2 text-sm text-[var(--color-text-muted)]">
                    <span class="text-[var(--color-text-faint)] mt-1.5 shrink-0" aria-hidden="true">
                      <svg width="6" height="6" viewBox="0 0 6 6" fill="currentColor">
                        <circle cx="3" cy="3" r="3"/>
                      </svg>
                    </span>
                    <span>
                      {mod.name}
                      {mod.notes && <span class="text-[var(--color-text-faint)] ml-1.5">- {mod.notes}</span>}
                    </span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </details>
    </div>

    <!-- Dissertations -->
    <div class="reveal" style="transition-delay: 0.2s;">
      <h3 class="text-sm font-mono text-[var(--color-accent)] uppercase tracking-widest mb-5">
        Dissertations
      </h3>
      <div class="space-y-5">
        {dissertations.map((d) => (
          <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-[var(--radius-card)] p-6 hover:border-[var(--color-border-hover)] transition-colors duration-200">
            <div class="flex flex-wrap items-start justify-between gap-3 mb-1">
              <h4 class="text-base font-semibold text-[var(--color-text)] leading-snug max-w-2xl">
                {d.title}
              </h4>
              <span class="text-xs font-mono text-[var(--color-text-faint)] shrink-0">{d.date}</span>
            </div>
            <p class="text-xs text-[var(--color-accent)] font-medium mb-3">{d.subtitle}</p>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed mb-4">{d.abstract}</p>
            <a
              href={d.pdfPath}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] transition-colors font-medium"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                <polyline points="7 10 12 15 17 10"/>
                <line x1="12" y1="15" x2="12" y2="3"/>
              </svg>
              Download PDF
            </a>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>
