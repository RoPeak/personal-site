---
import SectionHeading from '../ui/SectionHeading.astro';
import ProjectCard from '../ui/ProjectCard.astro';
import { featuredProjects } from '../../data/projects';
---

<section id="projects" class="section">
  <div class="container">
    <SectionHeading
      title="Featured Projects"
      subtitle="Personal projects built to explore and sharpen skills outside of work."
    />

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-10">
      {featuredProjects.map((project, i) => (
        <div class="reveal" style={`transition-delay: ${i * 0.1}s`}>
          <ProjectCard project={project} />
        </div>
      ))}
    </div>

    <div class="reveal flex justify-center">
      <a href="/projects" class="all-projects-btn">
        View all projects
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12" />
          <polyline points="12 5 19 12 12 19" />
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .all-projects-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1.25rem;
    border-radius: var(--radius-card);
    border: 1px solid var(--color-border-accent);
    background-color: var(--color-accent-muted);
    color: var(--color-accent);
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    transition: background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }
  .all-projects-btn:hover {
    background-color: rgba(99, 102, 241, 0.2);
    border-color: var(--color-accent);
    color: var(--color-accent-hover);
    transform: translateY(-1px);
  }
</style>
