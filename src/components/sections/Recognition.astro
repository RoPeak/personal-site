---
import SectionHeading from '../ui/SectionHeading.astro';
import { awards } from '../../data/awards';

const sorted = [...awards].sort((a, b) => a.order - b.order);

const typeLabel: Record<string, string> = {
  certification: 'Certification',
  award: 'Award',
  recognition: 'Recognition',
  volunteer: 'Volunteer',
};
---

<section id="recognition" class="section">
  <div class="container">
    <SectionHeading title="Recognition" />

    <div class="grid sm:grid-cols-2 gap-5">
      {sorted.map((item, i) => (
        <div
          class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-[var(--radius-card)] p-5 flex gap-4 hover:border-[var(--color-border-hover)] transition-colors duration-200 reveal"
          style={`transition-delay: ${i * 0.1}s`}
        >
          {/* Badge image or fallback icon */}
          <div class="shrink-0 w-12 h-12 flex items-center justify-center rounded-lg bg-[var(--color-surface-raised)] border border-[var(--color-border)] overflow-hidden">
            {item.badgeImage ? (
              <img
                src={item.badgeImage}
                alt={`${item.title} badge`}
                width="48"
                height="48"
                class="w-10 h-10 object-contain"
                loading="lazy"
              />
            ) : (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-[var(--color-accent)]" aria-hidden="true">
                <circle cx="12" cy="8" r="6"/>
                <path d="M8.21 13.89L7 23l5-3 5 3-1.21-9.12"/>
              </svg>
            )}
          </div>

          <div class="flex-1 min-w-0">
            <div class="flex flex-wrap items-start justify-between gap-x-3 gap-y-0.5 mb-1">
              <h3 class="text-sm font-semibold text-[var(--color-text)] leading-snug">
                {item.title}
              </h3>
              <span class="text-xs font-mono text-[var(--color-text-faint)] shrink-0">
                {item.date}
              </span>
            </div>
            <p class="text-xs text-[var(--color-accent)] font-medium mb-1.5">
              {item.issuer} &middot; {typeLabel[item.type]}
            </p>
            <p class="text-xs text-[var(--color-text-muted)] leading-relaxed">
              {item.description}
            </p>
            {item.verifyUrl && (
              <a
                href={item.verifyUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-2 inline-block text-xs text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] transition-colors"
              >
                Verify credential &rarr;
              </a>
            )}
          </div>
        </div>
      ))}
    </div>

    <!-- ScotlandIS event photo -->
    <div class="mt-10 reveal" style="transition-delay: 0.2s;">
      <div class="rounded-xl overflow-hidden border border-[var(--color-border)] max-w-lg">
        <img
          src="/assets/images/digital-tech-awards-night.jpg"
          alt="ScotlandIS Digital Technology Awards 2026 - Ronan Peacock as a finalist for Digital Tech Rising Star"
          width="600"
          height="400"
          class="w-full object-cover opacity-85 hover:opacity-100 transition-opacity duration-300"
          loading="lazy"
        />
      </div>
      <p class="mt-2 text-xs text-[var(--color-text-faint)]">
        ScotlandIS Digital Technology Awards 2026, Glasgow - Digital Tech Rising Star finalist
      </p>
    </div>
  </div>
</section>
