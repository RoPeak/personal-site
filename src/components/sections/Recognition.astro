---
import SectionHeading from '../ui/SectionHeading.astro';
import { awards } from '../../data/awards';

const sorted = [...awards].sort((a, b) => a.order - b.order);

const typeLabel: Record<string, string> = {
  certification: 'Certification',
  award: 'Award',
  recognition: 'Recognition',
  volunteer: 'Volunteer',
};

const typeAccent: Record<string, string> = {
  certification: '#f59e0b',
  award: '#6366f1',
  recognition: '#10b981',
  volunteer: '#3b82f6',
};
---

<section id="recognition" class="section section-tinted">
  <div class="container">
    <SectionHeading title="Recognition" />

    <div class="grid sm:grid-cols-2 gap-4 mb-12">
      {sorted.map((item, i) => (
        <div
          class="award-card card p-5 flex gap-4 reveal"
          style={`transition-delay: ${i * 0.1}s; --type-color: ${typeAccent[item.type]};`}
        >
          <!-- Badge / icon -->
          <div class="shrink-0 w-16 h-16 flex items-center justify-center rounded-lg overflow-hidden bg-[var(--color-surface-raised)] border border-[var(--color-border)]">
            {item.badgeImage ? (
              <img
                src={item.badgeImage}
                alt={`${item.title} badge`}
                width="56"
                height="56"
                class="w-14 h-14 object-contain"
                loading="lazy"
              />
            ) : (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style={`color: ${typeAccent[item.type]}`} aria-hidden="true">
                <circle cx="12" cy="8" r="6"/>
                <path d="M8.21 13.89L7 23l5-3 5 3-1.21-9.12"/>
              </svg>
            )}
          </div>

          <div class="flex-1 min-w-0">
            <div class="flex flex-wrap items-start justify-between gap-x-3 gap-y-0.5 mb-0.5">
              <h3 class="text-sm font-semibold text-[var(--color-text)] leading-snug pr-2">
                {item.title}
              </h3>
              <span class="text-xs font-mono text-[var(--color-text-faint)] shrink-0 mt-0.5">
                {item.date}
              </span>
            </div>
            <p class="text-xs font-medium mb-1.5" style={`color: ${typeAccent[item.type]}`}>
              {item.issuer} &middot; {typeLabel[item.type]}
            </p>
            <p class="text-xs text-[var(--color-text-muted)] leading-relaxed">
              {item.description}
            </p>
            {item.verifyUrl && (
              <a
                href={item.verifyUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-2 inline-block text-xs text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] transition-colors"
              >
                Verify credential &rarr;
              </a>
            )}
            {item.links && item.links.map((link) => (
              <a
                href={link.url}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-1.5 inline-block text-xs text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] transition-colors"
              >
                {link.label} &rarr;
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Event photo -->
    <div class="reveal" style="transition-delay: 0.2s;">
      <div class="relative overflow-hidden rounded-xl border border-[var(--color-border)] max-w-lg">
        <img
          src="/assets/images/digital-tech-awards-night.jpg"
          alt="ScotlandIS Digital Technology Awards 2026 - Ronan Peacock as finalist for Digital Tech Rising Star"
          width="620"
          height="400"
          class="w-full object-cover transition-opacity duration-300 opacity-80 hover:opacity-100"
          loading="lazy"
        />
        <div class="absolute bottom-0 left-0 right-0 px-4 py-3 bg-gradient-to-t from-black/70 to-transparent">
          <p class="text-xs text-white/80">
            ScotlandIS Digital Technology Awards 2026 - Digital Tech Rising Star finalist
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
