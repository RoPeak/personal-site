---
interface Props {
  title: string;
  subtitle?: string;
  id?: string;
}
const { title, subtitle, id } = Astro.props;
---

<div class="mb-12 reveal">
  <h2
    id={id}
    class="text-3xl md:text-4xl font-extrabold tracking-tight text-[var(--color-text)] mb-3"
  >
    {title}
  </h2>
  {subtitle && (
    <p class="text-[var(--color-text-muted)] max-w-xl leading-relaxed text-sm md:text-base">
      {subtitle}
    </p>
  )}
  <div class="mt-4 h-px w-20 section-rule" aria-hidden="true"></div>
</div>

<style>
  .section-rule {
    background: linear-gradient(to right, var(--color-accent), rgba(99, 102, 241, 0));
    border-radius: 1px;
  }
</style>
