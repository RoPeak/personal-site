---
interface Props {
  title: string;
  subtitle?: string;
  id?: string;
}
const { title, subtitle, id } = Astro.props;
---

<div class="mb-12 reveal">
  <h2
    id={id}
    class="text-3xl md:text-4xl font-bold tracking-tight text-[var(--color-text)] mb-3"
  >
    {title}
  </h2>
  {subtitle && (
    <p class="text-[var(--color-text-muted)] max-w-xl leading-relaxed">
      {subtitle}
    </p>
  )}
  <div class="mt-4 w-12 h-0.5 bg-[var(--color-accent)] rounded-full"></div>
</div>
