---
interface Photo {
  src: string;
  alt: string;
}

interface Props {
  photos: Photo[];
  /** Seconds each photo is fully visible */
  duration?: number;
  class?: string;
}

const { photos, duration = 3, class: className = '' } = Astro.props;
const count = photos.length;
const total = count * duration;
const slicePct = 100 / count;

// Per-slice: 10% fade in, 60% hold, 10% fade out, 20% gap
// Timing is fully encoded in keyframe percentages - no animation-delay needed
function getStops(i: number) {
  const base = i * slicePct;
  return {
    fadeIn:  +(base + slicePct * 0.10).toFixed(2),
    holdEnd: +(base + slicePct * 0.70).toFixed(2),
    fadeOut: +(base + slicePct * 0.80).toFixed(2),
  };
}

const dynamicCSS = photos.map((_, i) => {
  const s = getStops(i);
  const startOpacity = i === 0 ? 1 : 0;
  return `
@keyframes slideshow-${i} {
  0%         { opacity: ${startOpacity}; }
  ${s.fadeIn}%  { opacity: 1; }
  ${s.holdEnd}% { opacity: 1; }
  ${s.fadeOut}% { opacity: 0; }
  100%       { opacity: 0; }
}
@media (prefers-reduced-motion: no-preference) {
  .slide-${i} { animation-name: slideshow-${i}; }
}`;
}).join('\n');
---

<div class={`slideshow ${className}`} aria-label="Photo slideshow">
  {photos.map((photo, i) => (
    <img
      src={photo.src}
      alt={i === 0 ? photo.alt : ''}
      width="400"
      height="480"
      loading={i === 0 ? 'eager' : 'lazy'}
      class={`slide slide-${i}`}
      aria-hidden={i !== 0 ? 'true' : undefined}
    />
  ))}
</div>

<style define:vars={{ totalDuration: `${total}s` }}>
  .slideshow {
    position: relative;
    width: 100%;
    aspect-ratio: 5 / 6;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  .slide {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    opacity: 0;
  }

  .slide-0 {
    opacity: 1;
  }

  @media (prefers-reduced-motion: no-preference) {
    .slide {
      animation-duration: var(--totalDuration);
      animation-timing-function: ease-in-out;
      animation-iteration-count: infinite;
      animation-fill-mode: both;
    }
  }
</style>

<style set:html={dynamicCSS} />
