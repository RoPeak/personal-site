---
interface Photo {
  src: string;
  alt: string;
}

interface Props {
  photos: Photo[];
  /** Seconds each photo is fully visible (crossfade overlap excluded) */
  duration?: number;
  class?: string;
}

const { photos, duration = 4, class: className = '' } = Astro.props;
const count = photos.length;

// Total cycle = count * duration seconds.
// Each slide occupies (1/count) of the cycle.
// Within that slice: 15% fade in, 55% hold, 15% fade out, 15% off.
const total = count * duration;
const slicePct = 100 / count;

function getStops(i: number) {
  const base = i * slicePct;
  return {
    fadeIn:  +(base + slicePct * 0.15).toFixed(2),
    holdEnd: +(base + slicePct * 0.70).toFixed(2),
    fadeOut: +(base + slicePct * 0.85).toFixed(2),
  };
}

// Build the CSS string in the frontmatter so it can be injected via set:html
const dynamicCSS = photos.map((_, i) => {
  const s = getStops(i);
  // Slide 0 starts at opacity 1 (visible on load), others start at 0
  const startOpacity = i === 0 ? 1 : 0;
  return `
@keyframes slideshow-${i} {
  0%         { opacity: ${startOpacity}; }
  ${s.fadeIn}%  { opacity: 1; }
  ${s.holdEnd}% { opacity: 1; }
  ${s.fadeOut}% { opacity: 0; }
  100%       { opacity: 0; }
}
@media (prefers-reduced-motion: no-preference) {
  .slide-${i} {
    animation-name: slideshow-${i};
    animation-delay: ${i * duration}s;
  }
}`;
}).join('\n');
---

<div class={`slideshow ${className}`} aria-label="Photo slideshow">
  {photos.map((photo, i) => (
    <img
      src={photo.src}
      alt={i === 0 ? photo.alt : ''}
      width="400"
      height="480"
      loading={i === 0 ? 'eager' : 'lazy'}
      class={`slide slide-${i}`}
      aria-hidden={i !== 0 ? 'true' : undefined}
    />
  ))}
</div>

<style define:vars={{ totalDuration: `${total}s` }}>
  .slideshow {
    position: relative;
    width: 100%;
    aspect-ratio: 5 / 6;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  .slide {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    opacity: 0;
  }

  /* Fallback: first slide always visible */
  .slide-0 {
    opacity: 1;
  }

  @media (prefers-reduced-motion: no-preference) {
    .slide {
      animation-duration: var(--totalDuration);
      animation-timing-function: ease-in-out;
      animation-iteration-count: infinite;
      animation-fill-mode: both;
    }
  }
</style>

<!-- Per-slide keyframes generated from component props -->
<style set:html={dynamicCSS} />
