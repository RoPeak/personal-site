---
interface Photo {
  src: string;
  alt: string;
}

interface Props {
  photos: Photo[];
  /** Seconds each photo is fully visible */
  duration?: number;
  /** Seconds for each crossfade transition */
  crossfade?: number;
  class?: string;
}

const { photos, duration = 3, crossfade = 0.5, class: className = '' } = Astro.props;
const count = photos.length;
const total = count * duration;

// fadePct: what fraction of the total cycle the crossfade occupies
const fadePct = +((crossfade / total) * 100).toFixed(3);
const slicePct = +(100 / count).toFixed(3);

// Slide 0: visible at start, fades out at its slot end, then fades BACK IN near 100%
// to create a seamless loop with slide N-1. No animation-delay used.
function buildKeyframes(i: number): string {
  if (i === 0) {
    const holdEnd = +(slicePct - fadePct).toFixed(2);
    const fadeEnd = +slicePct.toFixed(2);
    const loopFadeIn = +(100 - fadePct).toFixed(2);
    return `@keyframes ss-0 {
  0%           { opacity: 1; }
  ${holdEnd}%  { opacity: 1; }
  ${fadeEnd}%  { opacity: 0; }
  ${loopFadeIn}% { opacity: 0; }
  100%         { opacity: 1; }
}`;
  }

  const fadeInStart = +(i * slicePct - fadePct).toFixed(2);
  const visible = +(i * slicePct).toFixed(2);
  const holdEnd = +((i + 1) * slicePct - fadePct).toFixed(2);
  const fadeEnd = +((i + 1) * slicePct).toFixed(2);
  return `@keyframes ss-${i} {
  0%              { opacity: 0; }
  ${fadeInStart}% { opacity: 0; }
  ${visible}%     { opacity: 1; }
  ${holdEnd}%     { opacity: 1; }
  ${fadeEnd}%     { opacity: 0; }
  100%            { opacity: 0; }
}`;
}

const dynamicCSS = photos
  .map(
    (_, i) => `
${buildKeyframes(i)}
@media (prefers-reduced-motion: no-preference) {
  .slide-${i} { animation-name: ss-${i}; }
}`
  )
  .join('\n');
---

<div class={`slideshow ${className}`} aria-label="Photo slideshow">
  {photos.map((photo, i) => (
    <img
      src={photo.src}
      alt={photo.alt}
      width="400"
      height="480"
      loading={i === 0 ? 'eager' : 'lazy'}
      class={`slide slide-${i}`}
      aria-hidden={photo.alt ? undefined : 'true'}
    />
  ))}
</div>

<style define:vars={{ totalDuration: `${total}s` }}>
  .slideshow {
    position: relative;
    width: 100%;
    aspect-ratio: 5 / 6;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  .slide {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    opacity: 0;
  }

  /* First slide visible before JS/animation kicks in */
  .slide-0 { opacity: 1; }

  @media (prefers-reduced-motion: no-preference) {
    .slide {
      animation-duration: var(--totalDuration);
      animation-timing-function: ease-in-out;
      animation-iteration-count: infinite;
      animation-fill-mode: both;
    }
  }
</style>

<style set:html={dynamicCSS} />
