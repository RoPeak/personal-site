---
import TechTag from './TechTag.astro';
import type { Project } from '../../data/projects';

interface Props {
  project: Project;
}
const { project } = Astro.props;

const primaryUrl = project.liveUrl ?? project.githubUrl;
const primaryLabel = project.liveUrl
  ? `View ${project.title} live`
  : `View ${project.title} on GitHub`;
---

<article class="project-card card flex flex-col overflow-hidden">
  {project.screenshot && (
    <a
      href={primaryUrl}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={primaryLabel}
      class="screenshot-wrap"
    >
      <img
        src={project.screenshot}
        alt={`${project.title} screenshot`}
        width="600"
        height="340"
        class="w-full object-cover object-top"
        loading="lazy"
      />
    </a>
  )}
  <div class="flex-1 p-6">
    <div class="flex items-start justify-between gap-4 mb-2">
      <svg
        class="text-[var(--color-accent)] shrink-0 mt-0.5"
        width="22"
        height="22"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        aria-hidden="true"
      >
        <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
      </svg>

      {project.liveUrl && (
        <a
          href={project.githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`View ${project.title} on GitHub`}
          class="text-[var(--color-text-faint)] hover:text-[var(--color-text-muted)] transition-colors duration-200"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
        </a>
      )}
    </div>

    <a
      href={primaryUrl}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={primaryLabel}
      class="project-main-link block"
    >
      <h3 class="project-title text-base font-bold text-[var(--color-text)] mb-1.5 mt-3 transition-colors duration-200">
        {project.title}
      </h3>
      <p class="text-sm text-[var(--color-text-muted)] leading-relaxed mb-5">
        {project.description}
      </p>
      <div class="flex flex-wrap gap-1.5 pt-4 border-t border-[var(--color-border)]">
        {project.tags.slice(0, 6).map((tag) => <TechTag label={tag} />)}
        {project.tags.length > 6 && (
          <span class="inline-block px-2 py-0.5 text-xs font-mono text-[var(--color-text-faint)]">
            +{project.tags.length - 6}
          </span>
        )}
      </div>
    </a>
  </div>
</article>

<style>
  .project-card {
    cursor: default;
  }
  .project-main-link,
  .screenshot-wrap {
    text-decoration: none;
  }
  .project-card:hover .project-title,
  .project-main-link:hover .project-title {
    color: var(--color-accent);
  }
  .screenshot-wrap {
    display: block;
    height: 180px;
    overflow: hidden;
    border-bottom: 1px solid var(--color-border);
  }
  .screenshot-wrap img {
    height: 100%;
    transition: transform 0.4s ease;
  }
  .project-card:hover .screenshot-wrap img {
    transform: scale(1.03);
  }
</style>
