---
import { site } from '../../data/site';

const navLinks = [
  { label: 'About', href: '/#about' },
  { label: 'Experience', href: '/#experience' },
  { label: 'Projects', href: '/projects' },
  { label: 'Skills', href: '/#skills' },
  { label: 'Recognition', href: '/#recognition' },
  { label: 'Education', href: '/#education' },
  { label: 'Contact', href: '/#contact' },
];
---

<header
  id="site-nav"
  class="fixed top-0 left-0 right-0 z-40 transition-all duration-300"
  style="background: transparent;"
>
  <nav class="container" aria-label="Main navigation">
    <div class="flex items-center justify-between h-16">

      <!-- Logo / Name -->
      <a href="/" class="nav-logo" aria-label="Ronan Peacock - home">
        Ronan Peacock
      </a>

      <!-- Desktop nav links -->
      <ul class="hidden md:flex items-center gap-5" role="list">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors duration-200"
            >
              {link.label}
            </a>
          </li>
        ))}
        <li>
          <a
            href={site.github}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub profile"
            class="text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors duration-200"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z" />
            </svg>
          </a>
        </li>
      </ul>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="menu-icon-open" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
        <svg id="menu-icon-close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" class="hidden">
          <line x1="18" y1="6" x2="6" y2="18" />
          <line x1="6" y1="6" x2="18" y2="18" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <nav
    id="mobile-menu"
    class="hidden md:hidden border-t border-[var(--color-border)] bg-[var(--color-surface)]"
    aria-label="Mobile navigation"
    aria-hidden="true"
  >
    <ul class="container py-4 flex flex-col gap-1" role="list">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="block py-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors"
          >
            {link.label}
          </a>
        </li>
      ))}
      <li class="pt-2 border-t border-[var(--color-border)] mt-2">
        <a
          href={site.github}
          target="_blank"
          rel="noopener noreferrer"
          class="block py-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors"
        >
          GitHub
        </a>
      </li>
    </ul>
  </nav>
</header>

<style>
  .nav-logo {
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    text-decoration: none;
    color: var(--color-text);
    transition: color 0.2s ease;
  }
  .nav-logo:hover {
    color: var(--color-accent);
  }
</style>

