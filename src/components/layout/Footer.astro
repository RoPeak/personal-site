---
import { site } from '../../data/site';
---

<footer class="border-t border-[var(--color-border)] py-10 mt-20">
  <div class="container flex flex-col sm:flex-row items-center justify-between gap-5">
    <p class="text-sm text-[var(--color-text-faint)]">
      &copy; {new Date().getFullYear()} Ronan Peacock &#129434;
    </p>
    <div class="flex items-center gap-5 flex-wrap justify-center">
      <a
        href={site.github}
        target="_blank"
        rel="noopener noreferrer"
        class="footer-link"
        aria-label="GitHub"
      >GitHub</a>
      <a
        href={site.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="footer-link"
        aria-label="LinkedIn"
      >LinkedIn</a>
      <a
        class="footer-link"
        aria-label="Send me an email"
        data-eu="contact"
        data-ed="ronanpeacock.com"
        role="link"
        tabindex="0"
      >Email</a>
      <a
        href={site.cvPath}
        target="_blank"
        rel="noopener noreferrer"
        class="footer-cv"
      >
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        <span>CV</span>
        <span class="footer-cv-date">Updated {site.cvLastUpdated}</span>
      </a>
    </div>
  </div>
</footer>

<style>
  .footer-link {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .footer-link:hover {
    color: var(--color-text);
  }
  .footer-cv {
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.35rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-accent);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .footer-cv:hover {
    color: var(--color-accent-hover);
  }
  .footer-cv-date {
    font-size: 0.75rem;
    color: var(--color-text-faint);
    font-weight: 400;
  }
</style>
