{
  "name": "personal-site",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0 <24"
  },
  "scripts": {
    "predev": "node ./scripts/check-node-version.mjs",
    "prebuild": "node ./scripts/check-node-version.mjs",
    "prepreview": "node ./scripts/check-node-version.mjs",
    "prepare": "node ./scripts/install-git-hooks.mjs",
    "compress": "node ./scripts/compress-images.mjs",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "format": "biome format --write src",
    "typecheck": "astro check",
    "ci": "npm run lint && npm run typecheck && npm run build"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.3.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@biomejs/biome": "^1.9.4",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3"
  }
}
